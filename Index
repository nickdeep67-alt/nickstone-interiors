<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>NickStone Interiors | Drywall & Framing in Calgary</title>
  <meta name="description" content="NickStone Interiors provides drywall installation, taping, steel stud framing, and renovation services in Calgary." />
  <style>
    :root{
      --bg:#0b0b0b;
      --card:#151515;
      --red:#c62828;
      --red2:#e53935;
      --text:#f5f5f5;
      --muted:#bdbdbd;
      --line:#2a2a2a;
      --white:#ffffff;
    }
    *{box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{
      margin:0;
      font-family:Arial, Helvetica, sans-serif;
      background:var(--bg);
      color:var(--text);
      line-height:1.6;
    }
    a{color:inherit;text-decoration:none}
    .container{
      width:min(1120px, 92%);
      margin:auto;
    }
    .topbar{
      position:sticky;
      top:0;
      z-index:10;
      background:rgba(11,11,11,.92);
      backdrop-filter: blur(10px);
      border-bottom:1px solid var(--line);
    }
    .nav{
      display:flex;
      align-items:center;
      justify-content:space-between;
      padding:14px 0;
      gap:18px;
    }
    .logo{
      font-weight:800;
      font-size:1.2rem;
      letter-spacing:.5px;
    }
    .logo span{color:var(--red2)}
    .nav-links{
      display:flex;
      gap:18px;
      flex-wrap:wrap;
      font-size:.95rem;
    }
    .btn{
      display:inline-block;
      background:linear-gradient(135deg,var(--red),var(--red2));
      color:var(--white);
      padding:12px 18px;
      border-radius:12px;
      font-weight:700;
    }
    .btn.outline{
      background:transparent;
      border:1px solid #666;
    }
    .hero{
      background:
        linear-gradient(rgba(0,0,0,.55), rgba(0,0,0,.75)),
        linear-gradient(135deg, #1c1c1c, #0b0b0b);
      padding:80px 0 70px;
      border-bottom:1px solid var(--line);
    }
    .hero-grid{
      display:grid;
      grid-template-columns:1.2fr .8fr;
      gap:28px;
      align-items:center;
    }
    h1{
      font-size:clamp(2.2rem, 5vw, 4.2rem);
      line-height:1.05;
      margin:0 0 16px;
    }
    .accent{color:var(--red2)}
    .lead{
      color:#e0e0e0;
      font-size:1.1rem;
      max-width:700px;
      margin-bottom:24px;
    }
    .hero-card{
      background:var(--card);
      border:1px solid var(--line);
      border-radius:18px;
      padding:24px;
      box-shadow:0 10px 30px rgba(0,0,0,.28);
    }
    .hero-card h3{margin-top:0}
    .pill-wrap{
      display:flex;
      flex-wrap:wrap;
      gap:10px;
      margin:18px 0 26px;
    }
    .pill{
      border:1px solid #444;
      color:#f1f1f1;
      padding:8px 12px;
      border-radius:999px;
      font-size:.9rem;
      background:#111;
    }
    section{
      padding:70px 0;
      border-bottom:1px solid var(--line);
    }
    .section-title{
      font-size:2rem;
      margin:0 0 12px;
    }
    .section-sub{
      color:var(--muted);
      max-width:760px;
      margin-bottom:28px;
    }
    .cards{
      display:grid;
      grid-template-columns:repeat(4,1fr);
      gap:18px;
    }
    .card{
      background:var(--card);
      border:1px solid var(--line);
      border-radius:18px;
      padding:22px;
    }
    .card h3{
      margin-top:0;
      margin-bottom:10px;
      color:var(--white);
    }
    .muted{color:var(--muted)}
    .about-grid,
    .contact-grid{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:24px;
    }
    ul.clean{
      padding-left:18px;
      margin:0;
    }
    .stats{
      display:grid;
      grid-template-columns:repeat(3,1fr);
      gap:16px;
      margin-top:20px;
    }
    .stat{
      background:#101010;
      border:1px solid var(--line);
      border-radius:16px;
      padding:18px;
      text-align:center;
    }
    .stat strong{
      display:block;
      font-size:1.6rem;
      color:var(--red2);
      margin-bottom:6px;
    }
    .cta{
      text-align:center;
      background:linear-gradient(180deg, #151515, #0f0f0f);
      border:1px solid var(--line);
      border-radius:22px;
      padding:34px;
    }
    footer{
      padding:24px 0 40px;
      color:#cfcfcf;
      text-align:center;
    }
    .contact-box{
      background:var(--card);
      border:1px solid var(--line);
      border-radius:18px;
      padding:22px;
    }
    .contact-box p{
      margin:8px 0;
    }
    .small{
      font-size:.92rem;
      color:var(--muted);
    }
    @media (max-width:900px){
      .hero-grid,.about-grid,.contact-grid,.cards{
        grid-template-columns:1fr;
      }
      .stats{
        grid-template-columns:1fr;
      }
      .nav{
        flex-direction:column;
        align-items:flex-start;
      }
    }
  </style>
</head>
